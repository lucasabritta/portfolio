{
  "name": "portfolio",
  "version": "0.1.0",
  "private": true,
  "packageManager": "yarn@1.22.22",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "engines": {
    "node": ">=22.12.0"
  },
  "resolutions": {
    "vite": "^5.4.21",
    "vite-tsconfig-paths": "4.3.2"
  },
  "scripts": {
    "dev": "yarn workspace @portfolio/frontend dev",
    "dev:docker": "yarn workspace @portfolio/frontend dev:docker",
    "build": "yarn workspace @portfolio/frontend build",
    "start": "yarn workspace @portfolio/frontend start",
    "start:docker": "yarn workspace @portfolio/frontend start:docker",
    "lint": "eslint --max-warnings=0",
    "lint:frontend": "eslint --max-warnings=0 apps/frontend eslint.config.mjs",
    "lint:backend": "eslint --max-warnings=0 apps/backend",
    "lint:resume-content": "eslint --max-warnings=0 packages/resume-content",
    "lint:storybook": "eslint --max-warnings=0 packages/storybook tools",
    "typecheck:resume-content": "tsc --noEmit -p packages/resume-content/tsconfig.json",
    "typecheck:storybook": "tsc --noEmit -p packages/storybook/tsconfig.json",
    "typecheck:backend": "tsc --noEmit -p apps/backend/tsconfig.json",
    "typecheck:frontend": "tsc --noEmit -p apps/frontend/tsconfig.json",
    "typecheck": "yarn typecheck:resume-content && yarn typecheck:storybook && yarn typecheck:backend && yarn typecheck:frontend",
    "test": "vitest run",
    "test:unit": "vitest run",
    "test:unit:frontend": "vitest run --project unit-frontend",
    "test:unit:backend": "vitest run --project unit-backend",
    "test:unit:resume-content": "vitest run --project unit-resume-content",
    "test:storybook": "yarn workspace @portfolio/storybook test:storybook",
    "test:watch": "vitest",
    "storybook": "yarn workspace @portfolio/storybook storybook",
    "build-storybook": "yarn workspace @portfolio/storybook build-storybook",
    "cv:dump:docker": "docker compose run --rm -e RENDER_CV_PDF=1 -e CV_PDF_OUT=/app/tmp-cv-compare/docker-latest-cv.pdf frontend yarn vitest run --project unit-backend apps/backend/src/cv-pdf/cv-pdf-dump.test.ts"
  },
  "devDependencies": {
    "@vitest/coverage-v8": "3.2.4",
    "eslint": "^9",
    "eslint-config-next": "16.2.3",
    "jsdom": "^24.1.3",
    "pdf-parse": "1.1.1",
    "playwright": "^1.59.1",
    "typescript": "^5",
    "vitest": "^3.2.4"
  }
}

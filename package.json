{
  "name": "portfolio",
  "version": "0.1.0",
  "private": true,
  "packageManager": "yarn@1.22.22",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "engines": {
    "node": ">=22.12.0"
  },
  "resolutions": {
    "vite": "^5.4.21",
    "vite-tsconfig-paths": "4.3.2"
  },
  "scripts": {
    "dev": "yarn workspace @portfolio/web dev",
    "dev:docker": "yarn workspace @portfolio/web dev:docker",
    "build": "yarn workspace @portfolio/web build",
    "start": "yarn workspace @portfolio/web start",
    "start:docker": "yarn workspace @portfolio/web start:docker",
    "lint": "eslint --max-warnings=0",
    "typecheck": "tsc --noEmit -p packages/cv/tsconfig.json && tsc --noEmit -p packages/web-ui/tsconfig.json && tsc --noEmit -p apps/web/tsconfig.json",
    "test": "vitest run",
    "test:unit": "vitest run",
    "test:storybook": "yarn workspace @portfolio/web-ui test:storybook",
    "test:watch": "vitest",
    "storybook": "yarn workspace @portfolio/web-ui storybook",
    "build-storybook": "yarn workspace @portfolio/web-ui build-storybook",
    "cv:dump:docker": "docker compose run --rm -e RENDER_CV_PDF=1 -e CV_PDF_OUT=/app/tmp-cv-compare/docker-latest-cv.pdf web yarn vitest run apps/web/lib/cv-pdf/cv-pdf-dump.test.ts"
  },
  "devDependencies": {
    "@vitest/coverage-v8": "3.2.4",
    "eslint": "^9",
    "eslint-config-next": "16.2.3",
    "jsdom": "^24.1.3",
    "pdf-parse": "1.1.1",
    "playwright": "^1.59.1",
    "typescript": "^5",
    "vitest": "^3.2.4"
  }
}

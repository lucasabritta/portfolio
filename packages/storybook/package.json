{
  "name": "@portfolio/storybook",
  "version": "0.1.0",
  "private": true,
  "packageManager": "yarn@1.22.22",
  "engines": {
    "node": ">=22.12.0"
  },
  "exports": {
    ".": "./src/index.ts",
    "./globals.css": "./src/globals.css",
    "./layout.module.css": "./src/layout.module.css"
  },
  "types": "./src/index.ts",
  "files": [
    "src"
  ],
  "scripts": {
    "storybook": "storybook dev -p 6006 --host 0.0.0.0 --no-open",
    "build-storybook": "storybook build",
    "test:storybook": "vitest run --config vitest.config.mjs",
    "lint": "eslint --max-warnings=0 src .storybook",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "test": "yarn test:storybook"
  },
  "dependencies": {},
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@storybook/addon-a11y": "^10.3.5",
    "@storybook/addon-docs": "10.3.5",
    "@storybook/addon-vitest": "^10.3.5",
    "@storybook/nextjs-vite": "^10.3.5",
    "@storybook/react": "10.3.5",
    "@tailwindcss/postcss": "^4",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.0",
    "@types/node": "^22",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitest/browser": "3.2.4",
    "eslint": "^9.39.4",
    "next": "16.2.4",
    "playwright": "^1.59.1",
    "react": "19.2.5",
    "react-dom": "19.2.5",
    "storybook": "^10.3.5",
    "tailwindcss": "^4",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.58.2",
    "vite": "^5.4.21",
    "vitest": "^3.2.4"
  }
}

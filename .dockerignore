# Git / CI (not needed in image)
.git
.github

# Dependencies — hoisted at repo root and any workspace copies
node_modules
**/node_modules

# Next.js — apps/frontend (and any future App Router apps)
**/.next
**/out

# Storybook static export — packages/storybook / embedded under Next public
**/storybook-static
apps/frontend/public/storybook

# Test / coverage artifacts
coverage
**/coverage

# Repo-root build output only (do not ignore `apps/frontend/app/build/` App Router segment)
/build/

# Logs & local env
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.env
.env.*
!.env.example

# Docs (keep README for optional COPY in slim images)
*.md
!README.md

# OS / editor
.DS_Store

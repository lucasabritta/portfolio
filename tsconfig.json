{
  "compilerOptions": {
    "target": "ES2017",
    "lib": ["dom", "dom.iterable", "esnext"],
    "allowJs": true,
    "skipLibCheck": true,
    "strict": true,
    "noEmit": true,
    "esModuleInterop": true,
    "module": "esnext",
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "jsx": "react-jsx",
    "baseUrl": ".",
    "paths": {
      "@/*": ["./apps/frontend/*"],
      "@portfolio/resume-content": ["./packages/resume-content/src/index.ts"],
      "@portfolio/storybook": ["./packages/storybook/src/index.ts"],
      "@ui/*": ["./packages/storybook/src/*"]
    }
  },
  "include": [
    "apps/frontend/**/*.ts",
    "apps/frontend/**/*.tsx",
    "apps/backend/**/*.ts",
    "apps/backend/**/*.tsx",
    "packages/resume-content/**/*.ts",
    "packages/storybook/**/*.ts",
    "packages/storybook/**/*.tsx",
    "packages/storybook/.storybook/**/*.ts",
    "packages/storybook/.storybook/**/*.tsx",
    "vitest.setup.ts",
    "vitest.shims.d.ts",
    "tools/**/*.mjs"
  ],
  "exclude": ["node_modules", "apps/frontend/.next", "**/storybook-static"]
}

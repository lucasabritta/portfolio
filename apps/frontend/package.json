{
  "name": "@portfolio/frontend",
  "version": "0.1.0",
  "private": true,
  "packageManager": "yarn@1.22.22",
  "engines": {
    "node": ">=22.12.0"
  },
  "resolutions": {
    "@react-pdf/image": "3.0.4"
  },
  "scripts": {
    "dev": "next dev",
    "dev:docker": "node ../../tools/ensure-storybook-public.mjs && next dev --hostname 0.0.0.0 --port 3000",
    "prebuild": "node ../../tools/build-storybook-for-next.mjs",
    "build": "next build",
    "start": "next start",
    "start:docker": "next start --hostname 0.0.0.0 --port 3000",
    "lint": "eslint --max-warnings=0 .",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "test": "vitest run",
    "test:unit": "vitest run"
  },
  "dependencies": {
    "@portfolio/resume-content": "file:../../packages/resume-content",
    "@portfolio/storybook": "file:../../packages/storybook",
    "@react-pdf/renderer": "^4.5.1",
    "@vercel/analytics": "^2.0.1",
    "@vercel/speed-insights": "^2.0.0",
    "next": "16.2.4",
    "react": "19.2.5",
    "react-dom": "19.2.5"
  },
  "devDependencies": {
    "@types/node": "^22",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@tailwindcss/postcss": "^4",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.0",
    "eslint": "^9.39.4",
    "eslint-config-next": "16.2.4",
    "jsdom": "^24.1.3",
    "playwright": "^1.59.1",
    "storybook": "^10.3.5",
    "tailwindcss": "^4",
    "typescript": "^5",
    "vitest": "^3.2.4"
  }
}

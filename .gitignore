# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies (root + any workspace that materializes its own node_modules)
node_modules/

# yarn / pnp
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
coverage/
**/coverage/

# next.js — apps/frontend (and any future apps/*)
**/.next/
out/

# storybook — packages/storybook (and any package that runs storybook build)
**/storybook-static/
# Storybook static bundle embedded in Next (`yarn build` / Vercel)
apps/frontend/public/storybook/

# optional package build outputs (if a workspace starts emitting to dist/)
**/dist/

# production / misc build dirs
build/

# misc
.DS_Store
*.pem
tmp-cv-compare/
cv-compare-generated.pdf

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# typescript
*.tsbuildinfo
